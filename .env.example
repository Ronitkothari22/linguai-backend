DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres
AUTH_JWT_SECRET=your-custom-jwt-secret
GEMINI_API_KEY=your-gemini-api-key
ENVIRONMENT=development

# Deepgram (Realtime STT / optional TTS)
DEEPGRAM_API_KEY=apikey-goes-here
DEEPGRAM_WEBHOOK_SECRET=your-deepgram-webhook-signing-secret
DEEPGRAM_REALTIME_URL=wss://api.deepgram.com/v1/listen

# Optional: Redis for session store (recommended in production)
REDIS_URL=redis://localhost:6379/0

# Conversation session settings
CONVERSATION_SESSION_TTL_SECONDS=3600

# Toggle: if true, backend will mint/return Deepgram tokens; if false, client must provide its own
DEEPGRAM_PROXY=true
