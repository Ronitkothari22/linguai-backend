    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\",\n  \"password\": \"secret123\",\n  \"name\": \"Learner\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"login returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.environment.set(\"auth_token\", data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Onboarding",
      "item": [
        {
          "name": "POST /onboarding/setup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"Spanish\",\n  \"level\": \"beginner\",\n  \"goal\": \"travel\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/onboarding/setup",
              "host": ["{{base_url}}"],
              "path": ["onboarding", "setup"]
            }
          }
        }
      ]
    },
    {
      "name": "Lessons",
      "item": [
        {
          "name": "GET /lessons/today",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lessons/today",
              "host": ["{{base_url}}"],
              "path": ["lessons", "today"]
            }
          }
        },
        {
          "name": "POST /lessons/submit",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lesson_id\": \"replace-with-lesson-id\",\n  \"exercise_id\": \"replace-with-exercise-id\",\n  \"user_answer\": \"yo va al mercado ayer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/lessons/submit",
              "host": ["{{base_url}}"],
              "path": ["lessons", "submit"]
            }
          }
        },
        {
          "name": "GET /lessons/history",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lessons/history?limit=10&offset=0",
              "host": ["{{base_url}}"],
              "path": ["lessons", "history"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "GET /progress/dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/progress/dashboard",
              "host": ["{{base_url}}"],
              "path": ["progress", "dashboard"]
            }
          }
          ,
          {
            "name": "Conversations",
            "item": [
              {
                "name": "POST /conversations/session",
                "request": {
                  "method": "POST",
                  "header": [
                    {
                      "key": "Content-Type",
                      "value": "application/json"
                    },
                    {
                      "key": "Authorization",
                      "value": "Bearer {{auth_token}}"
                    }
                  ],
                  "body": {
                    "mode": "raw",
                    "raw": "{}"
                  },
                  "url": {
                    "raw": "{{base_url}}/conversations/session",
                    "host": ["{{base_url}}"],
                    "path": ["conversations", "session"]
                  }
                }
              },
              {
                "name": "POST /conversations/webhook/deepgram (simulate)",
                "event": [
                  {
                    "listen": "prerequest",
                    "script": {
                      "type": "text/javascript",
                      "exec": [
                        "// compute HMAC-SHA256 signature for the raw body using CryptoJS",
                        "const secret = pm.environment.get('deepgram_webhook_secret') || pm.collectionVariables.get('deepgram_webhook_secret');",
                        "const body = pm.request.body.raw || '';",
                        "const sig = CryptoJS.HmacSHA256(body, secret).toString();",
                        "pm.environment.set('dg_sig', sig);"
                      ]
                    }
                  }
                ],
                "request": {
                  "method": "POST",
                  "header": [
                    {
                      "key": "Content-Type",
                      "value": "application/json"
                    },
                    {
                      "key": "X-Deepgram-Signature",
                      "value": "sha256={{dg_sig}}"
                    }
                  ],
                  "body": {
                    "mode": "raw",
                    "raw": "{\n  \"session_id\": \"test-session\",\n  \"is_final\": true,\n  \"channels\": [\n    {\n      \"alternatives\": [\n        {\n          \"transcript\": \"hello world\"\n        }\n      ]\n    }\n  ]\n}"
                  },
                  "url": {
                    "raw": "{{base_url}}/conversations/webhook/deepgram",
                    "host": ["{{base_url}}"],
                    "path": ["conversations", "webhook", "deepgram"]
                  }
                }
              },
              {
                "name": "WS example — connect & sample messages",
                "request": {
                  "method": "GET",
                  "header": [
                    {
                      "key": "Authorization",
                      "value": "Bearer {{auth_token}}"
                    }
                  ],
                  "url": {
                    "raw": "ws://{{host_ws}}/conversations/ws/{{session_id}}?token={{auth_token}}",
                    "host": ["ws://{{host_ws}}"],
                    "path": ["conversations", "ws", "{{session_id}}"],
                    "query": [
                      {
                        "key": "token",
                        "value": "{{auth_token}}"
                      }
                    ]
                  },
                  "description": "WebSocket example for the realtime conversation flow.\n\nAfter connecting to `ws://{{host_ws}}/conversations/ws/{session_id}` send JSON messages like:\n\n`{\"type\": \"transcript\", \"text\": \"hello world\"}`\n\nServer replies with a JSON message containing assistant text and base64-encoded audio:\n\n`{\"type\": \"assistant\", \"text\": \"Tutor reply...\", \"audio_base64\": \"...\", \"audio_mime\": \"audio/mpeg\"}`"
                }
              },
            ]
          }
        },
        {
          "name": "GET /progress/weak-topics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/progress/weak-topics",
              "host": ["{{base_url}}"],
              "path": ["progress", "weak-topics"]
            }
          }
        }
      ]
    }
    ,
    {
      "name": "Transcript",
      "item": [
        {
          "name": "POST /conversations/transcript",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"replace-with-session-id\",\n  \"text\": \"hello, I want to practice\"\n}"
            },
            "description": "Accepts a final transcript and returns the assistant reply. Response JSON: {\"type\":\"assistant\", \"text\":\"...\", \"audio_base64\":\"...\", \"audio_mime\":\"audio/mpeg\"}",
            "url": {
              "raw": "{{base_url}}/conversations/transcript",
              "host": ["{{base_url}}"],
              "path": ["conversations", "transcript"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "host_ws",
      "value": "localhost:8000"
    }
  ]
}
